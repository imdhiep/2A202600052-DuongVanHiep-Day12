# Copy this file to .env and fill real values locally.
# Never commit the real .env file or any live secret.

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
WEB_CONCURRENCY=1

# App
APP_NAME=Production AI Agent
APP_VERSION=1.0.0

# LLM
OPENAI_API_KEY=your-openai-api-key
LLM_MODEL=gpt-4o-mini

# Security
AGENT_API_KEY=replace-with-a-long-random-api-key
JWT_SECRET=replace-with-a-long-random-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENABLE_DEMO_JWT_LOGIN=true
DEMO_ADMIN_USERNAME=student
DEMO_ADMIN_PASSWORD=demo123

# Rate limiting
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_WINDOW_SECONDS=60

# Budget guard
MONTHLY_BUDGET_USD=10.0
GLOBAL_MONTHLY_BUDGET_USD=100.0

# Stateful data kept outside the app for stateless scaling
REDIS_URL=redis://localhost:6379/0
REQUIRE_REDIS_IN_PRODUCTION=true
SESSION_TTL_SECONDS=86400
HISTORY_TURN_LIMIT=10

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
